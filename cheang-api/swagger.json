    "/api/v1/users/delete/{id}": {
      "delete": {
        "summary": "Delete user account",
        "tags": [
          "Users"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
